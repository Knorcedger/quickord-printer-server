<service>
  <id>printerServer</id>
  <name>printerServer</name>
  <description>This service runs the printer server app.</description>
  <executable>printerServer.exe</executable>
  <log mode="roll" />
  <!-- A non-zero exit is how the app asks to be restarted (see restartServer()
       in src/index.ts) and also how a genuine crash surfaces. Either way the
       service is brought back as WinSW's own child, so the process stays
       service-managed instead of being respawned detached.
       This is a Windows recovery action, written to the SCM at `install` time —
       copying a newer xml onto an existing install does NOT apply it. The
       matching `sc.exe failure` in applyServiceConfig() is what updates it
       there. -->
  <onfailure action="restart" delay="5 sec"/>
  <startmode>Automatic</startmode>
  <delayedAutoStart/>
  <depend>Tcpip</depend>
  <depend>Dnscache</depend>
  <depend>NlaSvc</depend>
</service>
